# ── Required ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── Deployment ────────────────────────────────────────────────
# PORT is auto-set by Render; default 5000 for local dev
PORT=5000

# APP_URL — where your FRONTEND lives (used for OAuth redirect URIs)
#   Local dev:  http://localhost:5000
#   Production: https://your-app.vercel.app
APP_URL=http://localhost:5000

# ALLOWED_ORIGINS — comma-separated origins for CORS
#   Local dev:  * (allow all)
#   Production: https://your-app.vercel.app
ALLOWED_ORIGINS=*

# ── Cloudinary (image hosting) ────────────────────────────────
# Get from: console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=dv9woxx8c
CLOUDINARY_API_KEY=798742369115115
CLOUDINARY_API_SECRET=-goB9r7oiBGUsRhfMf_j9FDUQ1Q

# ── Optional: OAuth (only needed for Google/GitHub social login) ──
# Get from: console.developers.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Get from: github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
