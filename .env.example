MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Optional – only needed for Google/GitHub social login
# Get from: console.developers.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Get from: github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# URL where your app runs (for OAuth redirect URIs)
APP_URL=http://localhost:5000
